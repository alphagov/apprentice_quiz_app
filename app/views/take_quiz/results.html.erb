<% content_for :page_title, "Quiz Results" %>
<% content_for :back_link, quiz_path(@quiz) %>

<p class="govuk-body">Congratulations, you've completed the quiz: <%= @quiz.title %></p>

<p class="govuk-body">You scored <%= @score %> out of <%= @quiz.questions.count %>.</p>

<% if @guest_username.present? %>
  <p class="govuk-body">Guest: <%= @guest_username %></p>
<% end %>

<div class="govuk-button-group">
  <%= render "govuk_publishing_components/components/button", { text: "Back to Dashboard", href: quizzes_path } %>
</div>
